# Copy to .env.local and fill in. NEVER commit .env.local (it is git-ignored).

# Anthropic — used by the DEPLOYED demo at runtime for grounded generation + citations.
# This is a pay-as-you-go API key from console.anthropic.com, BILLED SEPARATELY from a
# Claude Max subscription. (Claude Max powers Claude Code, which builds the app — not the
# app's own API calls.) Cost for this demo is cents.
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI — used ONLY for embeddings (text-embedding-3-small). Anthropic has no embeddings
# endpoint, so embeddings come from OpenAI. Also pay-as-you-go; pennies for this corpus.
OPENAI_API_KEY=sk-...
